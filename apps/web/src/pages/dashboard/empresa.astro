---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { isJwtExpired } from "@/lib/auth/jwt";
import { fetchMyChallenges, type ChallengeMine } from "@/lib/api/challenges";
import {
  challengeStatusLabels,
  publicationLabel,
} from "@/lib/challenges/labels";
import { readSessionFromCookies } from "@/lib/supabase/cookie-session";

const session = readSessionFromCookies(Astro.cookies);

if (!session?.access_token) {
  return Astro.redirect("/auth/login?redirect=/dashboard/empresa");
}

if (isJwtExpired(session.access_token)) {
  return Astro.redirect(
    "/auth/login?redirect=/dashboard/empresa&reason=session_expired",
  );
}

let challenges: ChallengeMine[] = [];
let errorMessage: string | null = null;

try {
  challenges = await fetchMyChallenges(session.access_token);
} catch (err) {
  errorMessage = err instanceof Error ? err.message : "Error al cargar retos";
}
---

<BaseLayout title="Mis retos — Empresa">
  <section>
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold">Mis retos tecnológicos</h1>
        <p class="mt-1 text-sm text-slate-600">
          Crea requerimientos con impacto sustentable, publica en el tablero y da seguimiento a
          propuestas académicas.
        </p>
      </div>
      <div class="flex gap-2">
        <a
          href="/dashboard/empresa/nuevo"
          class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700"
        >
          + Crear reto
        </a>
        <a href="/dashboard" class="rounded-lg border border-slate-300 px-4 py-2 text-sm text-slate-700 hover:bg-slate-50">
          Panel
        </a>
      </div>
    </div>

    {errorMessage && <p class="mt-4 text-red-600">{errorMessage}</p>}

    {
      challenges.length === 0 && !errorMessage && (
        <div class="mt-8 rounded-xl border border-dashed border-brand-200 bg-brand-50/50 p-8 text-center">
          <p class="text-slate-700">Aún no has creado retos.</p>
          <a
            href="/dashboard/empresa/nuevo"
            class="mt-4 inline-block rounded-lg bg-brand-600 px-5 py-2 text-sm font-semibold text-white hover:bg-brand-700"
          >
            Crear primer reto
          </a>
        </div>
      )
    }

    <ul class="mt-8 space-y-4">
      {
        challenges.map((c) => (
          <li class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <a
                  href={`/dashboard/empresa/${c.id}`}
                  class="text-lg font-semibold text-slate-900 hover:text-brand-600"
                >
                  {c.title}
                </a>
                <p class="mt-1 line-clamp-2 text-sm text-slate-600">{c.description}</p>
                <p class="mt-2 text-xs text-slate-500">
                  {challengeStatusLabels[c.status] ?? c.status}
                  {" · "}
                  {publicationLabel(c.published_at)}
                  {c.deadline
                    ? ` · Plazo postulación: ${new Date(c.deadline).toLocaleDateString("es-EC")}`
                    : ""}
                </p>
                {
                  c.categories.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-1">
                      {c.categories.map((cat) => (
                        <span class="rounded-full bg-emerald-50 px-2 py-0.5 text-xs text-emerald-800">
                          {cat.name_es}
                        </span>
                      ))}
                    </div>
                  )
                }
              </div>
              <a
                href={`/dashboard/empresa/${c.id}`}
                class="shrink-0 rounded-lg border border-brand-200 px-3 py-1.5 text-sm font-medium text-brand-700 hover:bg-brand-50"
              >
                Gestionar →
              </a>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
