---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AdminPanel from "@/islands/AdminPanel.astro";
import { createSupabaseServerClient } from "@/lib/supabase/server";
import {
  fetchAdminChallenges,
  fetchAdminProfiles,
  fetchAdminProposals,
  fetchAdminStats,
} from "@/lib/supabase/admin";
import { fetchMyProfile } from "@/lib/supabase/profile";

const supabase = createSupabaseServerClient(Astro.cookies);
const {
  data: { session },
} = await supabase.auth.getSession();

if (!session) {
  return Astro.redirect("/auth/login");
}

let profile = null;
let errorMessage: string | null = null;

let adminStats = null;
let adminProfiles: Awaited<ReturnType<typeof fetchAdminProfiles>> = [];
let adminChallenges: Awaited<ReturnType<typeof fetchAdminChallenges>> = [];
let adminProposals: Awaited<ReturnType<typeof fetchAdminProposals>> = [];

try {
  profile = await fetchMyProfile(supabase, session.user.id);
  if (!profile) {
    errorMessage = "No se encontró tu perfil. Contacta al administrador.";
  } else if (profile.role === "admin") {
    adminStats = await fetchAdminStats(supabase);
    adminProfiles = await fetchAdminProfiles(supabase);
    adminChallenges = await fetchAdminChallenges(supabase);
    adminProposals = await fetchAdminProposals(supabase);
  }
} catch (err) {
  errorMessage = err instanceof Error ? err.message : "Error al cargar el panel";
}

const roleLabels: Record<string, string> = {
  company: "Empresa",
  academic: "Académico",
  admin: "Administrador",
};

const isAdmin = profile?.role === "admin";
const isCompany = profile?.role === "company";
const isAcademic = profile?.role === "academic";
const companyPending = isCompany && profile?.approval_status === "pending";
const companyRejected = isCompany && profile?.approval_status === "rejected";
---

<BaseLayout title={isAdmin ? "Administración — B2E Loja" : "Panel — B2E Loja"}>
  <section>
    {errorMessage && (
      <p class="rounded-lg bg-red-50 p-4 text-red-800">{errorMessage}</p>
    )}

    {profile && !errorMessage && (
      <>
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div>
            <h1 class="text-2xl font-bold text-slate-900">
              {isAdmin ? "Panel de administración" : "Panel de trabajo"}
            </h1>
            <p class="mt-1 text-sm text-slate-600">
              {roleLabels[profile.role]} · {profile.full_name}
            </p>
          </div>
          {!isAdmin && (
            <a href="/retos" class="text-sm font-medium text-brand-600 hover:underline">
              Tablero de retos →
            </a>
          )}
        </div>

        {companyPending && (
          <div class="mt-6 rounded-lg border border-amber-300 bg-amber-50 p-4 text-amber-900">
            <p class="font-medium">Cuenta en revisión</p>
            <p class="mt-1 text-sm">
              Tu registro empresarial está pendiente de aprobación por la Cámara de Comercio / UNL.
              Podrás publicar retos cuando un administrador apruebe tu cuenta.
            </p>
          </div>
        )}

        {companyRejected && (
          <div class="mt-6 rounded-lg border border-red-300 bg-red-50 p-4 text-red-800">
            <p class="font-medium">Registro no aprobado</p>
            <p class="mt-1 text-sm">
              Tu solicitud fue rechazada. Contacta a la administración de la plataforma para más
              información.
            </p>
          </div>
        )}

        {isAdmin && adminStats && (
          <>
            <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm text-amber-800">Empresas pendientes</p>
                <p class="text-2xl font-bold text-amber-900">{adminStats.companiesPending}</p>
              </div>
              <div class="rounded-xl border border-slate-200 bg-white p-4">
                <p class="text-sm text-slate-500">Empresas totales</p>
                <p class="text-2xl font-bold">{adminStats.companies}</p>
              </div>
              <div class="rounded-xl border border-slate-200 bg-white p-4">
                <p class="text-sm text-slate-500">Retos / abiertos</p>
                <p class="text-2xl font-bold">
                  {adminStats.challenges} <span class="text-base font-normal text-slate-400">/ {adminStats.challengesOpen}</span>
                </p>
              </div>
              <div class="rounded-xl border border-slate-200 bg-white p-4">
                <p class="text-sm text-slate-500">Propuestas</p>
                <p class="text-2xl font-bold">{adminStats.proposals}</p>
              </div>
            </div>

            <AdminPanel
              stats={adminStats}
              profiles={adminProfiles}
              challenges={adminChallenges}
              proposals={adminProposals}
            />
          </>
        )}

        {isCompany && profile.approval_status === "approved" && (
          <div class="mt-8">
            <a
              href="/dashboard/empresa"
              class="inline-block rounded-xl border border-brand-200 bg-brand-50 px-6 py-4 hover:bg-brand-100"
            >
              <h2 class="font-semibold text-brand-900">Mis retos</h2>
              <p class="text-sm text-brand-800">Crear y gestionar retos sustentables</p>
            </a>
          </div>
        )}

        {isAcademic && (
          <div class="mt-8">
            <a
              href="/retos"
              class="inline-block rounded-xl border border-slate-200 bg-white px-6 py-4 hover:bg-slate-50"
            >
              <h2 class="font-semibold">Explorar retos abiertos</h2>
              <p class="text-sm text-slate-600">Postular soluciones a retos publicados</p>
            </a>
          </div>
        )}

        <form method="POST" action="/auth/logout" class="mt-10">
          <button type="submit" class="text-sm text-slate-500 hover:text-red-600">
            Cerrar sesión
          </button>
        </form>
      </>
    )}
  </section>
</BaseLayout>
