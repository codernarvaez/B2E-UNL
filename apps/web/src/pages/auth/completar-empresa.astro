---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CompanyCompleteForm from "@/islands/CompanyCompleteForm.astro";
import { needsCompanyProfileCompletion } from "@/lib/auth/company-profile";
import { readSessionFromCookies } from "@/lib/supabase/cookie-session";
import { createSupabaseServerClient } from "@/lib/supabase/server";
import { fetchMyProfile } from "@/lib/supabase/profile";

const session = readSessionFromCookies(Astro.cookies);
const supabase = createSupabaseServerClient(Astro.cookies);

if (!session) {
  return Astro.redirect("/auth/login?redirect=/auth/completar-empresa");
}

const profile = await fetchMyProfile(supabase, session.user.id);
if (profile?.role === "company" && !needsCompanyProfileCompletion(profile)) {
  return Astro.redirect("/dashboard/empresa");
}
---

<BaseLayout
  title="Completar registro empresarial — B2E Loja"
  description="Completa los datos comerciales de tu empresa tras iniciar sesión con Google o GitHub"
>
  <section class="mx-auto max-w-2xl">
    <h1 class="text-2xl font-bold text-slate-900">Completa tu registro empresarial</h1>
    <p class="mt-2 text-sm text-slate-600">
      Iniciaste sesión con Google o GitHub. Para publicar retos en la plataforma, confirma los datos
      comerciales de tu empresa. Un administrador revisará tu solicitud.
    </p>

    <CompanyCompleteForm />
  </section>
</BaseLayout>
