---
import "../styles/global.css";
import SessionExpiryBanner from "@/components/SessionExpiryBanner.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import SupabaseOfflineBanner from "@/components/SupabaseOfflineBanner.astro";
import { getServerSessionInfo } from "@/lib/auth/session-server";
import { getServerSessionSafe } from "@/lib/supabase/safe-session";

interface Props {
  title?: string;
  description?: string;
}

const { title = "B2E Loja", description = "Innovación y sustentabilidad" } = Astro.props;

const { session, offline: supabaseOffline, errorMessage: supabaseError } =
  await getServerSessionSafe(Astro.cookies);

if (supabaseOffline && supabaseError) {
  console.warn("[B2E] Supabase:", supabaseError);
}

const isAuthenticated = Boolean(session);
const sessionInfo = session ? getServerSessionInfo(session) : null;
const sessionBootstrapJson = sessionInfo ? JSON.stringify(sessionInfo) : "";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-900 text-xl antialiased">
    {supabaseOffline && <SupabaseOfflineBanner message={supabaseError} />}
    {isAuthenticated && !supabaseOffline && <SessionExpiryBanner />}
    <SiteHeader
      isAuthenticated={isAuthenticated}
      userEmail={session?.user.email ?? null}
    />
    <main class="mx-auto max-w-[1660px] px-8 py-8">
      <slot />
    </main>
    <SiteFooter />

    {
      sessionBootstrapJson && (
        <script
          id="session-bootstrap"
          type="application/json"
          set:html={sessionBootstrapJson}
        />
      )
    }

    {
      sessionBootstrapJson && (
        <script>
          import { initSessionManager } from "@/islands/SessionManager";

          const el = document.getElementById("session-bootstrap");
          if (el?.textContent) {
            try {
              const data = JSON.parse(el.textContent);
              initSessionManager(data);
            } catch {
              /* ignore */
            }
          }
        </script>
      )
    }
  </body>
</html>
