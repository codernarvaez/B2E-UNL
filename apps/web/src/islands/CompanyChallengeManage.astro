---
interface Props {
  challengeId: string;
}

const { challengeId } = Astro.props;
---

<div id="company-challenge-manage-root" class="mt-8 space-y-6" data-challenge-id={challengeId}>
  <section class="rounded-xl border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-slate-900">Seguimiento del reto</h2>
    <p class="mt-1 text-sm text-slate-500">
      Publica en el tablero, actualiza el estado del ciclo B2E y revisa propuestas académicas.
    </p>

    <dl class="mt-4 grid gap-3 sm:grid-cols-2">
      <div>
        <dt class="text-xs font-medium uppercase text-slate-500">Estado operativo</dt>
        <dd class="mt-1 font-medium" data-status-label>—</dd>
        <dd class="mt-0.5 text-sm text-slate-500" data-status-help></dd>
      </div>
      <div>
        <dt class="text-xs font-medium uppercase text-slate-500">Visibilidad</dt>
        <dd class="mt-1 font-medium" data-publication-label>—</dd>
      </div>
      <div>
        <dt class="text-xs font-medium uppercase text-slate-500">Creado</dt>
        <dd class="mt-1 text-sm" data-created-at>—</dd>
      </div>
      <div>
        <dt class="text-xs font-medium uppercase text-slate-500">Última actualización</dt>
        <dd class="mt-1 text-sm" data-updated-at>—</dd>
      </div>
    </dl>

    <div class="mt-6 flex flex-wrap gap-2" data-actions></div>
    <p data-action-error class="mt-3 hidden text-sm text-red-600" role="alert"></p>
  </section>

  <section class="rounded-xl border border-slate-200 bg-white p-6">
    <h2 class="text-lg font-semibold text-slate-900">Propuestas académicas</h2>
    <p class="mt-1 text-sm text-slate-500">Seguimiento de postulaciones vinculadas a este reto.</p>
    <ul class="mt-4 space-y-3" data-proposals-list>
      <li class="text-sm text-slate-500">Cargando…</li>
    </ul>
  </section>
</div>

<script>
  import { initCompanyChallengeManage } from "@/islands/CompanyChallengeManage";

  const root = document.getElementById("company-challenge-manage-root");
  if (root) initCompanyChallengeManage(root);
</script>
