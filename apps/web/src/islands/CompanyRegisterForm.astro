<div id="company-register-root" class="mt-6">
  <!-- ERROR GLOBAL (arriba del formulario) -->
  <p data-error class="hidden rounded-lg bg-red-50 p-3 text-sm text-red-700 mb-4" role="alert"></p>
  <p data-success class="hidden rounded-lg bg-green-50 p-3 text-sm text-green-800 mb-4" role="status"></p>

  <form class="space-y-6">
    <fieldset class="space-y-4 rounded-xl border border-slate-200 bg-white p-5">
      <legend class="text-sm font-semibold text-brand-800">Datos de la empresa</legend>

      <!-- RAZÓN SOCIAL -->
      <div>
        <label for="organization_name" class="block text-sm font-medium text-slate-700">
          Razón social / nombre comercial *
        </label>
        <input
          id="organization_name"
          type="text"
          required
          minlength="3"
          maxlength="100"
          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
          placeholder="Ej. Industrias Loja S.A."
        />
        <p data-field-error class="mt-1 text-xs text-red-600"></p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <!-- RUC -->
        <div>
          <label for="tax_id" class="block text-sm font-medium text-slate-700">RUC *</label>
          <div class="relative">
            <input
              id="tax_id"
              type="text"
              required
              minlength="10"
              maxlength="13"
              pattern="[0-9]{10,13}"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="Ej. 1791234567001"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>

        <!-- SECTOR -->
        <div>
          <label for="business_sector" class="block text-sm font-medium text-slate-700">
            Sector / actividad *
          </label>
          <input
            id="business_sector"
            type="text"
            required
            minlength="2"
            maxlength="50"
            class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
            placeholder="Ej. Agroindustria, manufactura"
          />
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>
      </div>

      <!-- DIRECCIÓN -->
      <div>
        <label for="address" class="block text-sm font-medium text-slate-700">Dirección comercial *</label>
        <input
          id="address"
          type="text"
          required
          minlength="5"
          maxlength="150"
          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
          placeholder="Ciudad, calle y número"
        />
        <p data-field-error class="mt-1 text-xs text-red-600"></p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <!-- TELÉFONO -->
        <div>
          <label for="phone" class="block text-sm font-medium text-slate-700">Teléfono *</label>
          <div class="relative">
            <input
              id="phone"
              type="tel"
              required
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="Ej. 0991234567"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>

        <!-- SITIO WEB -->
        <div>
          <label for="website" class="block text-sm font-medium text-slate-700">Sitio web</label>
          <div class="relative">
            <input
              id="website"
              type="url"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="https://miempresa.com"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>
      </div>
    </fieldset>

    <fieldset class="space-y-4 rounded-xl border border-slate-200 bg-white p-5">
      <legend class="text-sm font-semibold text-brand-800">Representante y acceso</legend>

      <!-- NOMBRE REPRESENTANTE -->
      <div>
        <label for="full_name" class="block text-sm font-medium text-slate-700">
          Nombre del representante *
        </label>
        <input
          id="full_name"
          type="text"
          required
          minlength="3"
          maxlength="100"
          class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
          placeholder="Ej. Juan García López"
        />
        <p data-field-error class="mt-1 text-xs text-red-600"></p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <!-- EMAIL -->
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700">Correo de acceso *</label>
          <div class="relative">
            <input
              id="email"
              type="email"
              required
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="empresa@ejemplo.com"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>

        <!-- EMAIL CONTACTO -->
        <div>
          <label for="contact_email" class="block text-sm font-medium text-slate-700">
            Correo de contacto comercial
          </label>
          <div class="relative">
            <input
              id="contact_email"
              type="email"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
              placeholder="Opcional"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <!-- CONTRASEÑA -->
        <div>
          <label for="password" class="block text-sm font-medium text-slate-700">Contraseña *</label>
          <div class="relative">
            <input
              id="password"
              type="password"
              required
              minlength="8"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
          <div class="mt-2 text-xs text-slate-600">
            <p class="font-medium">Requisitos:</p>
            <ul class="mt-1 space-y-1">
              <li>• Mínimo 8 caracteres</li>
              <li>• Una mayúscula (A-Z)</li>
              <li>• Una minúscula (a-z)</li>
              <li>• Un número (0-9)</li>
              <li>• Un símbolo (!@#$%^&*)</li>
            </ul>
          </div>
        </div>

        <!-- CONFIRMAR CONTRASEÑA -->
        <div>
          <label for="password_confirm" class="block text-sm font-medium text-slate-700">
            Confirmar contraseña *
          </label>
          <div class="relative">
            <input
              id="password_confirm"
              type="password"
              required
              minlength="8"
              class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 transition-all focus:outline-none focus:ring-2 focus:ring-brand-500"
            />
            <div class="pointer-events-none absolute right-3 top-4 hidden h-5 w-5 text-green-500" data-valid-icon>
              <svg fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          </div>
          <p data-field-error class="mt-1 text-xs text-red-600"></p>
        </div>
      </div>
    </fieldset>

    <button
      type="submit"
      class="w-full rounded-lg bg-brand-600 py-3 font-medium text-white transition-colors hover:bg-brand-700 disabled:opacity-50 disabled:cursor-not-allowed"
    >
      Registrar empresa
    </button>
    
    <div data-form-error class="hidden mt-3 rounded-lg bg-red-50 p-3 text-sm text-red-700" role="alert"></div>
  </form>
</div>

<script>
  import { initCompanyRegisterForm } from "./CompanyRegisterForm";

  const root = document.getElementById("company-register-root");
  if (root) initCompanyRegisterForm(root);
</script>