---
import type { ChallengePublic } from "@/lib/api/client";

interface Props {
  challenge: ChallengePublic;
}

const { challenge } = Astro.props;
const impact = challenge.environmental_impact;

// DEBUG: Log de privacy_mode
console.log(`[Challenge] "${challenge.title}" - privacy_mode: "${challenge.privacy_mode}"`);

// Usar privacy_mode del desafío
const privacyMode = challenge.privacy_mode || "pseudonymized";

// Estilos condicionales
const cardStyles = {
  anonymous: "border-amber-300 bg-gradient-to-br from-amber-50 to-amber-100",
  pseudonymized: "border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100",
  original: "border-slate-200 bg-white",
};

const privacyLabel = {
  anonymous: "🔒 Anónimo",
  pseudonymized: "🏢 Empresa registrada",
  original: "✓ Empresa verificada",
};

const privacyBadgeColor = {
  anonymous: "bg-amber-200 text-amber-800",
  pseudonymized: "bg-blue-200 text-blue-800",
  original: "bg-green-200 text-green-800",
};

const isAnonymous = privacyMode === "anonymous";
---

<article class={`rounded-xl border p-6 shadow-sm transition hover:shadow-md ${cardStyles[privacyMode as keyof typeof cardStyles]}`}>
  <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
    <div class="flex flex-wrap gap-2">
      {
        challenge.categories.map((cat) => (
          <span class="rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-700">
            {cat.name_es}
          </span>
        ))
      }
    </div>
    <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${privacyBadgeColor[privacyMode as keyof typeof privacyBadgeColor]}`}>
      {privacyLabel[privacyMode as keyof typeof privacyLabel]}
    </span>
  </div>

  <h2 class="text-xl font-semibold text-slate-900">
    <a href={`/retos/${challenge.id}`} class="hover:text-brand-600">
      {challenge.title}
    </a>
  </h2>

  {isAnonymous && (
    <p class="mt-1 text-xs italic text-slate-600">
      Empresa que mantiene su identidad confidencial
    </p>
  )}

  <p class="mt-2 line-clamp-3 text-slate-600">{challenge.description}</p>

  {
    impact?.summary && (
      <p class="mt-3 text-sm text-brand-800">
        <span class="font-medium">Impacto:</span> {impact.summary}
      </p>
    )
  }

  <div class="mt-4 flex flex-col gap-3 border-t border-current border-opacity-10 pt-3">
    <span class="text-xs text-slate-600">
      {challenge.deadline
        ? `Plazo: ${new Date(challenge.deadline).toLocaleDateString("es-EC")}`
        : "Sin plazo definido"}
    </span>

    {challenge.public_display_name && (
      <div class="text-xs font-medium text-slate-700">
        {isAnonymous ? "De:" : "Publicado por:"}{" "}
        <span class="italic">{challenge.public_display_name}</span>
      </div>
    )}

    <a href={`/retos/${challenge.id}`} class="font-medium text-brand-600 hover:underline">
      Ver detalle →
    </a>
  </div>
</article>
