---
import { awardedProjects } from "@/data/awarded-projects";

const categoryColors: Record<string, string> = {
  "Green Tech": "bg-emerald-100 text-emerald-800",
  Energía: "bg-amber-100 text-amber-800",
  "Economía circular": "bg-sky-100 text-sky-800",
};
---

<section
  class="mt-20 border-t border-slate-200 pt-16"
  aria-labelledby="awarded-projects-heading"
>
  <div class="text-center">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand-600">
      Casos de éxito
    </p>
    <h2 id="awarded-projects-heading" class="mt-2 text-3xl font-bold text-slate-900">
      Proyectos galardonados
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-slate-600">
      Iniciativas empresariales reconocidas por su impacto sustentable y vinculación con la academia.
      Esta sección se actualizará de forma continua con nuevos casos.
    </p>
  </div>

  <ul class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      awardedProjects.map((project) => (
        <li class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:border-brand-200 hover:shadow-md">
          <div class="border-b border-slate-100 bg-gradient-to-br from-brand-50 to-white px-5 py-4">
            <div class="flex items-start justify-between gap-2">
              <span
                class:list={[
                  "rounded-full px-2.5 py-0.5 text-xs font-medium",
                  categoryColors[project.category] ?? "bg-slate-100 text-slate-700",
                ]}
              >
                {project.category}
              </span>
              <span class="text-xs font-medium text-slate-500">{project.year}</span>
            </div>
            <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-brand-700">
              {project.company}
            </p>
            <h3 class="mt-1 text-lg font-bold leading-snug text-slate-900 group-hover:text-brand-800">
              {project.title}
            </h3>
          </div>

          <div class="flex flex-1 flex-col px-5 py-4">
            <p class="flex items-center gap-1.5 text-sm font-medium text-amber-800">
              <svg class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
              {project.award}
            </p>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-600">
              {project.impactSummary}
            </p>
            {
              project.partnerUniversity && (
                <p class="mt-4 border-t border-slate-100 pt-3 text-xs text-slate-500">
                  Vinculación académica: {project.partnerUniversity}
                </p>
              )
            }
          </div>
        </li>
      ))
    }
  </ul>

  <p class="mt-8 text-center text-xs text-slate-400">
    Datos ilustrativos — los proyectos reales se publicarán tras cada convocatoria B2E.
  </p>
</section>
