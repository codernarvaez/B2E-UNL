---
import { projects } from "@/data/projects";


const categoryColors: Record<string, string> = {
  "Finanzas": "bg-blue-100 text-blue-800",
  "Data Science": "bg-purple-100 text-purple-800",
  "Backend": "bg-indigo-100 text-indigo-800",
  "Mobile": "bg-violet-100 text-violet-800",
  "Frontend": "bg-fuchsia-100 text-fuchsia-800",
  "Seguridad": "bg-red-100 text-red-800",
};

const estateColors: Record<string, string> = {
  "Nuevo": "bg-blue-600 text-white",
  "En curso": "bg-amber-500 text-white",
  "Resuelto": "bg-emerald-500 text-white",
};
---


<ul class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
  {
    projects.map((project) => (
      <li class="group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:border-brand-200 hover:shadow-md">
        
        <div class="border-b border-slate-100 bg-gradient-to-br from-brand-50 to-white px-5 py-4">
          <div class="flex items-start justify-between gap-2">

            <span
              class:list={[
                "rounded-full px-2.5 py-0.5 text-xs font-medium",
                categoryColors[project.area] ?? "bg-slate-100 text-slate-700",
              ]}
            >
              {project.area}
            </span>
            
            <span 
                class:list={[
                "rounded px-2 py-0.5 text-xs font-bold uppercase tracking-wider",
                estateColors[project.estate] ?? "bg-slate-500 text-white"
                ]}
            >              
                {project.estate}            
            </span>
          </div>

          <p class="mt-3 text-xs font-medium text-slate-500">
            Publicado el {project.datePublish}
          </p>
          
          <h3 class="mt-1 text-lg font-bold leading-snug text-slate-900 group-hover:text-brand-800">
            {project.title}
          </h3>
        </div>

        <div class="flex flex-1 flex-col px-5 py-4">
          <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">
            {project.description}
          </p>
          
          <div class="mt-4 pt-3 border-t border-slate-100 text-center">
            <button class="w-full py-2 px-4 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors">
              Ver Detalles
            </button>
          </div>
        </div>

      </li>
    ))
  }
</ul>