<div
  id="session-expiry-banner"
  class="hidden border-b border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950"
  role="alert"
  aria-live="polite"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="flex items-start gap-2">
      <svg class="mt-0.5 h-5 w-5 shrink-0 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      <span data-session-message>Tu sesión está por terminar.</span>
    </p>
    <div class="flex flex-wrap items-center gap-2">
      <button
        type="button"
        data-session-extend
        class="rounded-lg bg-amber-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-amber-700"
      >
        Extender sesión
      </button>
      <button
        type="button"
        data-session-logout
        class="rounded-lg border border-amber-300 px-3 py-1.5 text-xs font-medium text-amber-900 hover:bg-amber-100"
      >
        Cerrar sesión
      </button>
      <button
        type="button"
        data-session-dismiss
        class="rounded-lg px-2 py-1.5 text-xs text-amber-800 hover:underline"
        aria-label="Ocultar aviso"
      >
        Ocultar
      </button>
    </div>
  </div>
</div>
