# =============================================================================
# B2E — Proyecto Supabase Cloud: hzfkoxvqtemflpokaqnw (b2e_)
# =============================================================================
# 1. Copia este archivo:  cp .env.example .env
# 2. Completa DB_PASSWORD y SUPABASE_JWT_SECRET desde el Dashboard:
#    https://supabase.com/dashboard/project/hzfkoxvqtemflpokaqnw/settings/api
#    (API → JWT Secret | Database → Database password)
# 3. Arranca: make dev-api && make dev-web
# 4. (Opcional) Admin local: ADMIN_PASSWORD=... make seed-admin
# =============================================================================

# Solo desarrollo local — NO commitear .env
ADMIN_PASSWORD=change-me-local-only

# --- Supabase API (URL base, SIN /rest/v1/) ---
SUPABASE_URL=https://hzfkoxvqtemflpokaqnw.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- PostgreSQL (FastAPI) ---
# Copia host/puerto/usuario EXACTOS desde Dashboard → Connect (no uses aws-0 si tu proyecto muestra aws-1)
# Este proyecto (hzfkoxvqtemflpokaqnw) usa típicamente:
DATABASE_URL=postgresql+psycopg://postgres.hzfkoxvqtemflpokaqnw:[DB_PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Session pooler (alternativa): mismo host, puerto 5432, mismo usuario postgres.[ref]

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:4321,http://127.0.0.1:4321

# --- Astro (expuesto al navegador) ---
PUBLIC_SUPABASE_URL=https://hzfkoxvqtemflpokaqnw.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
PUBLIC_API_URL=http://localhost:8000

# --- Sesión (JWT Supabase + inactividad en el navegador) ---
# Minutos sin actividad antes de cerrar sesión automáticamente
PUBLIC_SESSION_IDLE_MINUTES=30
# Minutos antes del vencimiento del JWT para mostrar aviso
PUBLIC_SESSION_WARN_MINUTES=5

# --- OAuth (Supabase Dashboard → Authentication → Providers) ---
# Habilita Google y GitHub; en URL Configuration añade:
#   http://127.0.0.1:4321/auth/callback
#   http://localhost:4321/auth/callback
# (y la URL de producción cuando despliegues)
