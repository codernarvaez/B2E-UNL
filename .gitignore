# =============================================================================
# B2E — Reglas para GitHub (no subir secretos ni artefactos generados)
# =============================================================================

# --- Variables de entorno y secretos ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account*.json
secrets/

# --- Dependencias ---
node_modules/
.pnp/
.pnp.js

# --- Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
pip-wheel-metadata/

# --- Builds y cachés ---
dist/
build/
out/
*.tsbuildinfo
apps/web/dist/
apps/web/.astro/
.vite/

# --- Logs y cobertura ---
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
apps/api/.pytest_cache/

# --- Supabase CLI (local) ---
supabase/.branches/
supabase/.temp/
supabase/.env

# --- IDE y herramientas locales ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.cursor/
.codegraph/

# --- Docker / despliegue local ---
*.local

# --- Sistema / misc ---
.cache/
.turbo/
.vercel/
.netlify/
