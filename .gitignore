# =============================================================================
# B2E — No subir secretos, dependencias ni artefactos generados
# Verificación: make verify-git  |  bash scripts/verify-before-push.sh
# =============================================================================

# --- Secretos y entorno ---
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
service-account*.json
secrets/

# --- Node.js (cualquier ubicación en el monorepo) ---
node_modules/
**/node_modules/
.pnp/
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Python ---
.venv/
venv/
env/
**/.venv/
**/__pycache__/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
**/*.egg-info/
.eggs/
pip-wheel-metadata/
.mypy_cache/
.ruff_cache/
.pytest_cache/
**/.pytest_cache/
htmlcov/
.coverage
.coverage.*

# --- Builds y cachés frontend ---
dist/
**/dist/
build/
out/
*.tsbuildinfo
.astro/
**/.astro/
.vite/
**/.vite/
.cache/
.turbo/

# --- Supabase CLI (local) ---
supabase/.branches/
supabase/.temp/
supabase/.env

# --- IDE, agentes y herramientas locales (no subir a GitHub) ---
.idea/
.vscode/
.cursor
.cursor/
**/.cursor/
.codegraph
.codegraph/
**/.codegraph/
assets/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Docker / despliegue ---
*.local
.vercel/
.netlify/

# --- Logs ---
*.log
logs/
